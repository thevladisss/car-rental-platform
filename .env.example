# Copy to .env and adjust values:
#   cp .env.example .env
#
# Loaded automatically by ./run.sh (or export these before ./mvnw spring-boot:run).

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/personalio
SPRING_DATASOURCE_USERNAME=personalio
SPRING_DATASOURCE_PASSWORD=personalio

# Docker Compose uses hostname `db` instead of localhost:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/personalio
